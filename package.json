{
  "name": "react-mcp-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/with-build-lock.mjs pnpm -r --filter './packages/**' run build",
    "build:src": "pnpm --filter vite-react-mcp run build:src",
    "dev": "pnpm -r --parallel --if-present run start",
    "playground": "pnpm --filter vite-react-app run start",
    "playground:nx-mf": "pnpm -C playground/nx-module-federation-monorepo run start",
    "format": "pnpm biome format --write",
    "lint": "pnpm biome lint --write",
    "check": "pnpm biome check --write",
    "test": "pnpm run test:e2e",
    "test:e2e": "node scripts/run-e2e.mjs"
  },
  "pnpm": {
    "overrides": {
      "@remix-run/router": "1.23.2",
      "caniuse-lite": "1.0.30001793",
      "fast-uri": "3.1.2",
      "js-yaml": "4.1.1",
      "lodash": "4.18.1",
      "minimatch": "3.1.5",
      "next": "15.5.18",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.2",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.2": "4.0.4",
      "postcss": "8.5.15",
      "qs": "6.15.2",
      "rollup": "4.60.4",
      "serialize-javascript": "7.0.5",
      "uuid": "11.1.1",
      "vite": "6.4.2",
      "webpack": "5.107.1",
      "webpack-dev-server": "5.2.4",
      "ws": "8.21.0",
      "yaml": "1.10.3"
    }
  },
  "packageManager": "pnpm@10.6.5",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "shx": "0.4.0",
    "typescript": "^5.8.2"
  }
}
