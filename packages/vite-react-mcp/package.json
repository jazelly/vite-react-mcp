{
  "name": "vite-react-mcp",
  "type": "module",
  "version": "0.3.0",
  "description": "Vite plugin for React MCP",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "shx rm -rf dist && tsc && shx cp ../../CHANGELOG dist/CHANGELOG",
    "build:src": "shx rm -rf dist && tsc --project tsconfig.json --outDir dist --rootDir src && shx cp ../../CHANGELOG dist/CHANGELOG"
  },
  "keywords": [
    "vite",
    "react",
    "mcp",
    "visual-edit",
    "agents",
    "devtools",
    "llm",
    "plugin"
  ],
  "author": {
    "name": "jazelly",
    "email": "xzha4350@gmail.com"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@babel/preset-react": ">=6",
    "vite": ">=4",
    "webpack": ">=5",
    "next": ">=13"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/types": "^7.27.0",
    "@rollup/pluginutils": "^5.1.4",
    "@types/react-reconciler": "0.26.7",
    "vite": "^6.2.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.7.0",
    "bippy": "^0.5.39",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.23.5",
    "ws": "^8.18.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bridge": {
      "types": "./dist/bridge/server.d.ts",
      "default": "./dist/bridge/server.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "default": "./dist/mcp/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "default": "./dist/next.js"
    },
    "./select": {
      "types": "./dist/select.d.ts",
      "default": "./dist/select.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "default": "./dist/webpack.js"
    }
  }
}
